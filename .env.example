# ------------------------------------------------------------------
# Home Control Centre — environment variables
# Copy this file to .env for local dev. In Railway, set these as
# service variables (Service → Variables tab).
# ------------------------------------------------------------------

# --- Runtime ---
NODE_ENV=production
# Railway injects PORT automatically. Local default is 3001.
PORT=3001

# --- Database (Railway Postgres plugin) ---
# In Railway, this is auto-populated as a reference to ${{Postgres.DATABASE_URL}}.
DATABASE_URL=postgres://user:pass@host:5432/dbname
# Set to "true" when connecting to a managed DB over the public network
# (Railway internal connections do not need SSL). Auto-enabled if URL
# contains sslmode=require.
DATABASE_SSL=false

# --- Auth ---
# 32+ random chars each. Generate with: openssl rand -base64 48
JWT_SECRET=
JWT_REFRESH_SECRET=

# --- CORS ---
# For a single-service deploy (API serves SPA from same origin), this can
# be left at the default. Override only if you host the web app on a
# different domain.
CORS_ORIGIN=http://localhost:5173

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- AI / LLM ---
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# --- Maps / Routing ---
GOOGLE_MAPS_API_KEY=
LINZ_BASEMAP_API_KEY=
OSRM_BASE_URL=https://router.project-osrm.org

# --- Static SPA path (only override if your container layout differs) ---
# Defaults to ../../web/dist relative to the compiled API entrypoint.
# WEB_DIST_DIR=/app/packages/web/dist
